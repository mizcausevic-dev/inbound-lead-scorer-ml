{
  "name": "inbound-lead-scorer-ml",
  "version": "1.1.0",
  "description": "Board-ready Kinetic Gain surface for scoring inbound leads using fit, behavior, attribution, and pipeline-priority signals.",
  "main": "dist/src/app.js",
  "scripts": {
    "dev": "tsx watch src/app.ts",
    "build": "tsc --pretty false",
    "test": "vitest run",
    "demo": "tsx scripts/run_demo.ts",
    "smoke": "tsx scripts/smoke_check.ts",
    "prerender": "tsx scripts/prerender.ts",
    "verify": "npm run build && npm run test && npm run demo && npm run smoke && npm run prerender",
    "render:assets": "powershell -ExecutionPolicy Bypass -File .\\scripts\\render_readme_assets.ps1"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mizcausevic-dev/inbound-lead-scorer-ml.git"
  },
  "license": "AGPL-3.0-or-later",
  "type": "commonjs",
  "bugs": {
    "url": "https://github.com/mizcausevic-dev/inbound-lead-scorer-ml/issues"
  },
  "homepage": "http://leads.kineticgain.com/",
  "dependencies": {
    "express": "^5.2.1"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/node": "^25.7.0",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "vitest": "^4.1.8"
  }
}
